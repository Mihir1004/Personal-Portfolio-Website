{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/portfolio-responsive-complete-main/assets/:path*"
    },
    {
      "source": "/portfolio-responsive-complete-main",
      "destination": "/portfolio-responsive-complete-main/index.html"
    },
    {
      "source": "/",
      "destination": "/portfolio-responsive-complete-main/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
